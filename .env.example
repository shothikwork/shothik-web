# shothik-web environment variables
#
# Rules:
# - Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.
# - Do not put secrets in NEXT_PUBLIC_ variables.
# - Do not commit .env.local or any real secret values.
#
# Setup:
#   cp .env.example .env.local
#   edit .env.local

################################################################################
# Public (Browser) – safe to expose
################################################################################

# App and external API routing
NEXT_PUBLIC_APP_URL=https://shothik.work
NEXT_PUBLIC_API_URL=https://shothik.work

# Some modules use a base URL that already includes a path prefix. If unsure,
# set this equal to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_URL_WITH_PREFIX=https://shothik.work

# Tool rewrites / socket prefixes
NEXT_PUBLIC_PARAPHRASE_REDIRECT_PREFIX=paraphrase

# Optional: if set, paraphrase socket connects directly to this URL.
# If unset, the app uses "/${NEXT_PUBLIC_PARAPHRASE_REDIRECT_PREFIX}/socket.io".
NEXT_PUBLIC_PARAPHRASE_SOCKET_URL=

# Optional: required for Sheet features (set to the service prefix used by your API).
NEXT_PUBLIC_SHEET_REDIRECT_PREFIX=

# Optional: used by the presentation tool for socket transport
NEXT_PUBLIC_SOCKET_URL=

# Convex URL is used by browser and some API routes
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Social login (if enabled in the UI)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Payments (public key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder

# Analytics and error tracking
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags
NEXT_PUBLIC_WRITING_STUDIO_ENABLED=true
NEXT_PUBLIC_WRITING_STUDIO_API_URL=
NEXT_PUBLIC_ENABLE_PARAPHRASE_SIMPLIFIED=true
NEXT_PUBLIC_EXTRACT_PDF_V2_ENABLED=false

################################################################################
# Server-only (Node / API routes) – secrets must live here
################################################################################

# Convex (server)
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment.convex.cloud

# Clerk (current/legacy auth in codebase – planned replacement)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register

# LLM providers (at least one required by env validation)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-thinking
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Stripe (server)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_CREDITS_WEBHOOK_SECRET=
STRIPE_STARS_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=
CREDIT_PURCHASE_SECRET=

# Razorpay (server)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=

# PublishDrive (publishing)
PUBLISHDRIVE_ENABLED=true
NEXT_PUBLIC_PUBLISHDRIVE_ENABLED=true
NEXT_PUBLIC_PUBLISHDRIVE_API_URL=https://api.publishdrive.com/v1
PUBLISHDRIVE_API_KEY=
PUBLISHDRIVE_WEBHOOK_SECRET=

# Calibre microservice
CALIBRE_SERVICE_URL=http://localhost:3003

# Redis / Upstash (used by idempotency and rate limiting helpers)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
REDIS_TOKEN=

# Security and ops
METRICS_ADMIN_KEY=
IP_ALLOWLIST=

# Optional: MongoDB (only required if features using dbConnect are enabled)
MONGODB_URI=

################################################################################
# Document parsing (LiteParse)
################################################################################

# Enable LiteParse extraction paths (server-side)
LITEPARSE_ENABLED=false
LITEPARSE_MODE=shadow
LITEPARSE_OCR_LANGUAGE=eng
LITEPARSE_OCR_SERVER_URL=
LITEPARSE_DPI=150
LITEPARSE_MAX_PAGES=40
LITEPARSE_NUM_WORKERS=1
LITEPARSE_DISABLE_OCR=false

################################################################################
# Future (planned) Better Auth + RBAC migration
################################################################################

# These are not fully wired in the current codebase yet. Keep them server-only.
BETTER_AUTH_URL=https://shothik.work
NEXT_PUBLIC_BETTER_AUTH_URL=https://shothik.work
BETTER_AUTH_SECRET=
DATABASE_URL=
